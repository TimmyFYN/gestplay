datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  winRate      Float    @default(0.0)
  gamesPlayed  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  matchesAsPlayer1 Match[] @relation("Player1Matches")
  matchesAsPlayer2 Match[] @relation("Player2Matches")
  wonMatches       Match[] @relation("WonMatches")
  moves            Move[]
  spectatedMatches SpectatorSession[]
}

model Match {
  id        String   @id @default(uuid())
  gameType  String   // CHESS, TICTACTOE
  status    String   @default("WAITING") // WAITING, ACTIVE, COMPLETED
  fen       String?  @default("rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1")
  boardState String? // JSON string for TicTacToe or other games
  startTime DateTime @default(now())
  endTime   DateTime?

  player1Id String
  player1   User     @relation("Player1Matches", fields: [player1Id], references: [id])
  
  player2Id String?
  player2   User?    @relation("Player2Matches", fields: [player2Id], references: [id])

  winnerId  String?
  winner    User?    @relation("WonMatches", fields: [winnerId], references: [id])

  moves     Move[]
  spectators SpectatorSession[]
}

model Move {
  id              String   @id @default(uuid())
  matchId         String
  match           Match    @relation(fields: [matchId], references: [id])
  playerId        String
  player          User     @relation(fields: [playerId], references: [id])
  moveNotation    String
  gestureUsed     String?
  confidenceScore Float?
  latencyMs       Int?
  timestamp       DateTime @default(now())
}

model SpectatorSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id])
  joinedAt  DateTime @default(now())
  leftAt    DateTime?
}


